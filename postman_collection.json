    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('timestamp', Date.now());",
          "if (!pm.collectionVariables.get('created_password')) {",
          "  pm.collectionVariables.set('created_password', 'Password123!');",
          "}",
          "if (!pm.collectionVariables.get('new_password')) {",
          "  pm.collectionVariables.set('new_password', 'Password123!New');",
          "}"
        ]
      }
