  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"QA User\",\n  \"email\": \"{{created_email}}\",\n  \"password\": \"{{created_password}}\",\n  \"password_confirmation\": \"{{created_password}}\",\n  \"device_name\": \"postman\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('timestamp', ts);",
                  "pm.collectionVariables.set('created_email', `test+${ts}@example.com`);",
                  "if (!pm.collectionVariables.get('created_password')) {",
                  "  pm.collectionVariables.set('created_password', 'Password123!');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has success wrapper', () => pm.expect(json).to.have.property('success'));",
                  "const token = json.data && json.data.access_token ? json.data.access_token : null;",
                  "if (token) { pm.collectionVariables.set('token', token); }",
                  "if (json.data && json.data.user && json.data.user.id) { pm.collectionVariables.set('user_id', json.data.user.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{created_email}}\",\n  \"password\": \"{{created_password}}\",\n  \"device_name\": \"postman\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const token = (json.data && json.data.access_token) || json.access_token;",
                  "pm.test('Token present', () => pm.expect(token).to.be.ok);",
                  "if (token) { pm.collectionVariables.set('token', token); }"
                ]
              }
            }
          ]
        },
